{
  "info": {
    "name": "CampusHub Testing Lab",
    "description": "CampusHub + BookNest 教学项目接口烟测集合。执行前建议重启后端，让 H2 示例数据回到初始状态。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "studentUsername",
      "value": "student02"
    },
    {
      "key": "studentPassword",
      "value": "campus123"
    },
    {
      "key": "adminUsername",
      "value": "admin01"
    }
  ],
  "item": [
    {
      "name": "00 System",
      "item": [
        {
          "name": "Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns UP', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "Overview",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('overview contains modules and statistics', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.modules.length).to.be.above(0);",
                  "  pm.expect(body.statistics.books).to.eql(20);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/overview"
          }
        },
        {
          "name": "OpenAPI JSON",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OpenAPI document is available', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().openapi).to.match(/^3\\./);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v3/api-docs"
          }
        }
      ]
    },
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Login as student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('student login succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.username).to.eql(pm.collectionVariables.get('studentUsername'));",
                  "  pm.expect(body.permissions).to.include('BOOK_BORROW');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{studentUsername}}\",\"password\":\"{{studentPassword}}\"}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login rejects wrong password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('wrong password returns 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"student01\",\"password\":\"wrong-password\"}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
