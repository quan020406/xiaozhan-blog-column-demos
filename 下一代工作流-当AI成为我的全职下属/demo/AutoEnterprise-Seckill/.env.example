# Copy this file to .env and replace every placeholder with values from your own environment.
#
# SERVER_PORT controls the Spring Boot HTTP port.
SERVER_PORT=<app-port>

# SECKILL_BASE_URL is used by manual API calls and the Python stress test.
# Use the externally reachable base URL of this application.
SECKILL_BASE_URL=http://<app-host>:<app-port>

# REDIS_ADDRESS is required only when running with the redis Spring profile.
# Use redis:// for plain Redis and rediss:// for TLS Redis.
REDIS_ADDRESS=redis://<redis-host>:<redis-port>

# REDIS_PASSWORD is optional. Leave it empty when Redis does not require a password.
REDIS_PASSWORD=
